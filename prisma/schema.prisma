generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AdmissionStatus {
  ADMITTED
  DISCHARGED
}

enum AdmissionType {
  INPATIENT
  OUTPATIENT
}

enum DispenseOrderStatus {
  PENDING
  PREPARING
  DISPENSED
  CANCELLED
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  CLEANED
}

model Patient {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @db.Uuid
  mrn         String
  name        String
  dateOfBirth DateTime?
  gender      Gender?
  phone       String?
  address     String?
  allergies   String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admissions     Admission[]
  dispenseOrders DispenseOrder[]

  @@index([orgId])
  @@index([orgId, mrn])
  @@unique([orgId, mrn])
}

model Admission {
  id              String          @id @default(uuid()) @db.Uuid
  orgId           String          @db.Uuid
  patientId       String          @db.Uuid
  type            AdmissionType   @default(INPATIENT)
  admissionNumber String
  admissionDate   DateTime
  dischargeDate   DateTime?
  roomId          String?         @db.Uuid
  diagnosis       String?
  status          AdmissionStatus @default(ADMITTED)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  patient        Patient          @relation(fields: [patientId], references: [id])
  room           Room?            @relation(fields: [roomId], references: [id])
  dispenseOrders DispenseOrder[]

  @@index([orgId])
  @@index([orgId, admissionNumber])
  @@unique([orgId, admissionNumber])
}

model RoomCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  isIntensive Boolean  @default(false)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms Room[]

  @@unique([name])
}

model Room {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String?  @db.Uuid
  categoryId String   @db.Uuid
  code       String
  name       String
  floor      String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category       RoomCategory    @relation(fields: [categoryId], references: [id])
  admissions     Admission[]

  @@index([orgId])
  @@unique([orgId, code])
}

model DispenseOrder {
  id            String              @id @default(uuid()) @db.Uuid
  orgId         String              @db.Uuid
  orderNumber   String
  orderDate     DateTime            @default(now()) @db.Date
  patientId     String              @db.Uuid
  admissionId   String              @db.Uuid
  dispensedAt   DateTime?
  notes         String?
  cancelReason  String?
  status        DispenseOrderStatus @default(PENDING)
  createdAt     DateTime            @default(now())
  createdBy     String              @db.Uuid
  updatedAt     DateTime            @updatedAt
  updatedBy     String?             @db.Uuid

  patient   Patient             @relation(fields: [patientId], references: [id])
  admission Admission          @relation(fields: [admissionId], references: [id])
  items     DispenseOrderItem[]

  @@index([orgId])
  @@index([orgId, orderNumber])
  @@unique([orgId, orderNumber])
  @@index([orgId, patientId])
  @@index([orgId, admissionId])
  @@index([orgId, status])
}

model DispenseOrderItem {
  id              String    @id @default(uuid()) @db.Uuid
  dispenseOrderId String    @db.Uuid
  drugId          String    
  quantity        Int
  instructions    String?
  createdAt       DateTime  @default(now())
  createdBy       String              @db.Uuid
  updatedAt       DateTime  @updatedAt
  updatedBy       String?              @db.Uuid

  dispenseOrder DispenseOrder @relation(fields: [dispenseOrderId], references: [id], onDelete: Cascade)

  @@index([dispenseOrderId])
}
