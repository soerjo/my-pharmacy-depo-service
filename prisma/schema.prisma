generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────

enum ProductType {
  FINISHED_GOOD
  RAW_MATERIAL
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum InboundShipmentStatus {
  PENDING
  RECEIVING
  COMPLETED
  CANCELLED
}

enum OutboundShipmentStatus {
  PENDING
  PICKING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum CompoundingStatus {
  PENDING
  MIXING
  QC_CHECK
  COMPLETED
  CANCELLED
  FAILED
}

enum LocationType {
  BULK_STORAGE
  PICKING
  COLD_STORAGE
  QUARANTINE
  LABORATORY
  DISPENSING
}

enum StockMovementType {
  INBOUND
  OUTBOUND
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  COMPOUNDING_IN
  COMPOUNDING_OUT
}

// ─── Master Data ────────────────────────────────────────────────────────

model UnitOfMeasure {
  id               String   @id @default(uuid())
  code             String
  name             String
  abbreviation     String?
  isBase           Boolean  @default(false)
  baseUnitId       String?
  baseUnit         UnitOfMeasure? @relation("UomHierarchy", fields: [baseUnitId], references: [id])
  derivedUnits     UnitOfMeasure[] @relation("UomHierarchy")
  conversionFactor Decimal? @db.Decimal(10, 4)
  isActive         Boolean  @default(true)
  organizationId   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  productBaseUnits       Product[] @relation("ProductBaseUnit")
  productStockingUnits   Product[] @relation("ProductStockingUnit")
  productSellingUnits    Product[] @relation("ProductSellingUnit")
  productPurchaseUnits   Product[] @relation("ProductPurchaseUnit")
  formulaYieldUnits      Formula[] @relation("FormulaYieldUom")
  formulaIngredientUoms  FormulaIngredient[] @relation("FormulaIngredientUom")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([isActive])
}

model Manufacturer {
  id             String   @id @default(uuid())
  code           String
  name           String
  contactEmail   String?
  contactPhone   String?
  address        String?
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products Product[]
  batches  Batch[]

  @@unique([organizationId, code])
  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([isActive])
}

model ProductCategory {
  id             String   @id @default(uuid())
  name           String
  description    String?
  parent         ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  parentId       String?
  children       ProductCategory[] @relation("CategoryHierarchy")
  products       Product[]
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([parentId])
}

model Product {
  id              String            @id @default(uuid())
  code            String
  name            String
  description     String?
  productType     ProductType       @default(FINISHED_GOOD)
  dosageForm      String?
  strength        String?
  casNumber       String?
  grade           String?
  minStock        Int               @default(0)
  maxStock        Int?
  category        ProductCategory   @relation(fields: [categoryId], references: [id])
  categoryId      String
  manufacturer    Manufacturer      @relation(fields: [manufacturerId], references: [id])
  manufacturerId  String
  baseUnit        UnitOfMeasure     @relation("ProductBaseUnit", fields: [baseUnitId], references: [id])
  baseUnitId      String
  stockingUnit    UnitOfMeasure     @relation("ProductStockingUnit", fields: [stockingUnitId], references: [id])
  stockingUnitId  String
  sellingUnit     UnitOfMeasure     @relation("ProductSellingUnit", fields: [sellingUnitId], references: [id])
  sellingUnitId   String
  purchaseUnit    UnitOfMeasure?    @relation("ProductPurchaseUnit", fields: [purchaseUnitId], references: [id])
  purchaseUnitId  String?
  isActive        Boolean           @default(true)
  organizationId  String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  batches               Batch[]
  batchInventory        BatchInventory[]
  purchaseOrderItems    PurchaseOrderItem[]
  inboundShipmentItems  InboundShipmentItem[]
  outboundShipmentItems OutboundShipmentItem[]
  stockMovements        StockMovement[]
  transfers             Transfer[]
  stockAdjustments      StockAdjustment[]
  formulaIngredients    FormulaIngredient[]
  compoundingMaterials  CompoundingBatchMaterial[]
  formulas              Formula[] @relation("FormulaProduct")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([productType])
  @@index([categoryId])
  @@index([manufacturerId])
  @@index([baseUnitId])
  @@index([stockingUnitId])
  @@index([sellingUnitId])
  @@index([isActive])
}

model Supplier {
  id             String   @id @default(uuid())
  code           String
  name           String
  contactEmail   String?
  contactPhone   String?
  address        String?
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  purchaseOrders   PurchaseOrder[]
  inboundShipments InboundShipment[]
  batches          Batch[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([isActive])
}

model WarehouseLocation {
  id             String       @id @default(uuid())
  code           String
  name           String
  zone           String?
  shelf          String?
  bin            String?
  locationType   LocationType
  isActive       Boolean      @default(true)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  batchInventory      BatchInventory[]
  inboundShipmentItems InboundShipmentItem[]
  transfersFrom       Transfer[] @relation("TransferFrom")
  transfersTo         Transfer[] @relation("TransferTo")
  stockMovements      StockMovement[]
  stockAdjustments    StockAdjustment[]
  compoundingBatches         CompoundingBatch[]
  outboundShipmentItems      OutboundShipmentItem[]
  compoundingBatchMaterials  CompoundingBatchMaterial[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([isActive])
  @@index([locationType])
}

// ─── Inventory ──────────────────────────────────────────────────────────

model Batch {
  id               String   @id @default(uuid())
  batchNumber      String
  expirationDate   DateTime
  manufacturingDate DateTime?
  receivedDate     DateTime @default(now())
  cost             Decimal  @db.Decimal(10, 2)
  isActive         Boolean  @default(true)
  product          Product  @relation(fields: [productId], references: [id])
  productId        String
  manufacturer     Manufacturer @relation(fields: [manufacturerId], references: [id])
  manufacturerId   String
  supplier         Supplier? @relation(fields: [supplierId], references: [id])
  supplierId       String?
  compoundingBatch CompoundingBatch? @relation("CompoundingProducedBatch", fields: [compoundingBatchId], references: [id])
  compoundingBatchId String? @unique
  organizationId   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  inboundShipmentItems  InboundShipmentItem[]
  outboundShipmentItems OutboundShipmentItem[]
  stockMovements        StockMovement[]
  stockAdjustments      StockAdjustment[]
  batchInventory        BatchInventory[]
  compoundingMaterials  CompoundingBatchMaterial[]
  transfers             Transfer[]

  @@unique([organizationId, batchNumber])
  @@index([organizationId])
  @@index([productId])
  @@index([manufacturerId])
  @@index([supplierId])
  @@index([compoundingBatchId])
  @@index([expirationDate])
  @@index([isActive])
  @@index([expirationDate, isActive])
}

model BatchInventory {
  id             String            @id @default(uuid())
  quantity       Int               @default(0)
  batch          Batch             @relation(fields: [batchId], references: [id])
  batchId        String
  product        Product           @relation(fields: [productId], references: [id])
  productId      String
  location       WarehouseLocation @relation(fields: [locationId], references: [id])
  locationId     String
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([batchId, locationId])
  @@index([organizationId])
  @@index([productId, locationId])
  @@index([productId])
  @@index([locationId])
  @@index([batchId])
}

// ─── Procurement (Inbound) ─────────────────────────────────────────────

model PurchaseOrder {
  id             String              @id @default(uuid())
  orderNumber    String
  orderDate      DateTime            @default(now())
  expectedDate   DateTime?
  status         PurchaseOrderStatus @default(DRAFT)
  totalAmount    Decimal             @db.Decimal(12, 2)
  notes          String?
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  supplierId     String
  organizationId String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  items            PurchaseOrderItem[]
  inboundShipments InboundShipment[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
}

model PurchaseOrderItem {
  id              String       @id @default(uuid())
  quantity        Int
  unitPrice       Decimal      @db.Decimal(10, 2)
  receivedQty     Int          @default(0)
  product         Product      @relation(fields: [productId], references: [id])
  productId       String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([purchaseOrderId, productId])
  @@index([purchaseOrderId])
  @@index([productId])
}

model InboundShipment {
  id               String                @id @default(uuid())
  shipmentNumber   String
  receivedDate     DateTime              @default(now())
  receivedBy       String
  status           InboundShipmentStatus @default(PENDING)
  notes            String?
  supplier         Supplier              @relation(fields: [supplierId], references: [id])
  supplierId       String
  purchaseOrder    PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId  String?
  organizationId   String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  items InboundShipmentItem[]

  @@unique([organizationId, shipmentNumber])
  @@index([organizationId])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([status])
  @@index([receivedDate])
}

model InboundShipmentItem {
  id                String            @id @default(uuid())
  quantity          Int
  batch             Batch             @relation(fields: [batchId], references: [id])
  batchId           String
  product           Product           @relation(fields: [productId], references: [id])
  productId         String
  location          WarehouseLocation @relation(fields: [locationId], references: [id])
  locationId        String
  inboundShipment   InboundShipment   @relation(fields: [inboundShipmentId], references: [id])
  inboundShipmentId String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([inboundShipmentId])
  @@index([batchId])
  @@index([productId])
  @@index([locationId])

  @@unique([inboundShipmentId, batchId])
}

// ─── Distribution (Outbound) ───────────────────────────────────────────

model OutboundShipment {
  id                 String                  @id @default(uuid())
  shipmentNumber     String
  destination        String
  destinationAddress String?
  shipmentDate       DateTime                @default(now())
  status             OutboundShipmentStatus  @default(PENDING)
  notes              String?
  organizationId     String
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  items OutboundShipmentItem[]

  @@unique([organizationId, shipmentNumber])
  @@index([organizationId])
  @@index([status])
  @@index([shipmentDate])
}

model OutboundShipmentItem {
  id                 String            @id @default(uuid())
  quantity           Int
  batch              Batch             @relation(fields: [batchId], references: [id])
  batchId            String
  product            Product           @relation(fields: [productId], references: [id])
  productId          String
  location           WarehouseLocation @relation(fields: [locationId], references: [id])
  locationId         String
  outboundShipment   OutboundShipment  @relation(fields: [outboundShipmentId], references: [id])
  outboundShipmentId String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([outboundShipmentId])
  @@index([batchId])
  @@index([productId])
  @@index([locationId])

  @@unique([outboundShipmentId, batchId])
}

// ─── Stock Operations ──────────────────────────────────────────────────

model StockMovement {
  id             String            @id @default(uuid())
  movementType   StockMovementType
  quantity       Int
  reason         String?
  product        Product           @relation(fields: [productId], references: [id])
  productId      String
  location       WarehouseLocation @relation(fields: [locationId], references: [id])
  locationId     String
  batch          Batch?            @relation(fields: [batchId], references: [id])
  batchId        String?
  referenceId    String?
  organizationId String
  createdAt      DateTime          @default(now())

  @@index([organizationId])
  @@index([productId])
  @@index([locationId])
  @@index([batchId])
  @@index([movementType])
  @@index([createdAt])
  @@index([organizationId, productId, locationId, createdAt])
}

model Transfer {
  id              String            @id @default(uuid())
  transferNumber  String
  transferDate    DateTime          @default(now())
  quantity        Int
  status          TransferStatus    @default(PENDING)
  notes           String?
  product         Product           @relation(fields: [productId], references: [id])
  productId       String
  batch           Batch             @relation(fields: [batchId], references: [id])
  batchId         String
  fromLocation    WarehouseLocation @relation("TransferFrom", fields: [fromLocationId], references: [id])
  fromLocationId  String
  toLocation      WarehouseLocation @relation("TransferTo", fields: [toLocationId], references: [id])
  toLocationId    String
  organizationId  String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([organizationId, transferNumber])
  @@index([organizationId])
  @@index([productId])
  @@index([batchId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
  @@index([transferDate])
}

model StockAdjustment {
  id               String            @id @default(uuid())
  adjustmentNumber String
  adjustmentDate   DateTime          @default(now())
  quantity         Int
  reason           String
  product          Product           @relation(fields: [productId], references: [id])
  productId        String
  location         WarehouseLocation @relation(fields: [locationId], references: [id])
  locationId       String
  batch            Batch?            @relation(fields: [batchId], references: [id])
  batchId          String?
  organizationId   String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([organizationId, adjustmentNumber])
  @@index([organizationId])
  @@index([productId])
  @@index([locationId])
  @@index([batchId])
  @@index([adjustmentDate])
}

// ─── Compounding / Laboratory ──────────────────────────────────────────

model Formula {
  id             String   @id @default(uuid())
  code           String
  name           String
  description    String?
  dosageForm     String?
  totalYield     Int
  yieldUnit      UnitOfMeasure @relation("FormulaYieldUom", fields: [yieldUnitId], references: [id])
  yieldUnitId    String
  instructions   String?
  product        Product  @relation("FormulaProduct", fields: [productId], references: [id])
  productId      String
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ingredients       FormulaIngredient[]
  compoundingBatches CompoundingBatch[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([productId])
  @@index([isActive])
}

model FormulaIngredient {
  id             String        @id @default(uuid())
  quantity       Decimal       @db.Decimal(10, 4)
  product        Product       @relation(fields: [productId], references: [id])
  productId      String
  unitOfMeasure  UnitOfMeasure @relation("FormulaIngredientUom", fields: [unitOfMeasureId], references: [id])
  unitOfMeasureId String
  formula        Formula       @relation(fields: [formulaId], references: [id])
  formulaId      String
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([formulaId, productId])
  @@index([formulaId])
  @@index([productId])
}

model CompoundingBatch {
  id               String            @id @default(uuid())
  batchNumber      String
  producedDate     DateTime          @default(now())
  expirationDate   DateTime
  quantity         Int
  status           CompoundingStatus @default(PENDING)
  notes            String?
  formula          Formula           @relation(fields: [formulaId], references: [id])
  formulaId        String
  location         WarehouseLocation @relation(fields: [locationId], references: [id])
  locationId       String
  producedBatch    Batch?            @relation("CompoundingProducedBatch")
  organizationId   String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  materials CompoundingBatchMaterial[]

  @@unique([organizationId, batchNumber])
  @@index([organizationId])
  @@index([formulaId])
  @@index([locationId])
  @@index([organizationId, status])
  @@index([expirationDate])
  @@index([producedDate])
}

model CompoundingBatchMaterial {
  id                   String            @id @default(uuid())
  quantityUsed         Decimal           @db.Decimal(10, 4)
  product              Product           @relation(fields: [productId], references: [id])
  productId            String
  batch                Batch             @relation(fields: [batchId], references: [id])
  batchId              String
  location             WarehouseLocation @relation(fields: [locationId], references: [id])
  locationId           String
  compoundingBatch     CompoundingBatch  @relation(fields: [compoundingBatchId], references: [id])
  compoundingBatchId   String
  createdAt            DateTime          @default(now())

  @@index([compoundingBatchId])
  @@index([productId])
  @@index([batchId])
  @@index([locationId])
}
