generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AdmissionStatus {
  ADMITTED
  DISCHARGED
}

enum LocationType {
  DEPOT
  WARD
  DEPARTMENT
}

enum DispenseType {
  INPATIENT
  OUTPATIENT
}

enum DispenseOrderStatus {
  PENDING
  PREPARING
  DISPENSED
  CANCELLED
}

model Patient {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @db.Uuid
  mrn         String
  name        String
  dateOfBirth DateTime?
  gender      Gender?
  phone       String?
  address     String?
  allergies   String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admissions    Admission[]
  dispenseOrders DispenseOrder[]

  @@index([orgId])
  @@index([orgId, mrn])
  @@unique([orgId, mrn])
}

model Admission {
  id              String          @id @default(uuid()) @db.Uuid
  orgId           String          @db.Uuid
  patientId       String          @db.Uuid
  admissionNumber String
  admissionDate   DateTime
  dischargeDate   DateTime?
  wardId          String?         @db.Uuid
  diagnosis       String?
  status          AdmissionStatus @default(ADMITTED)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  patient        Patient          @relation(fields: [patientId], references: [id])
  ward           Location?        @relation(fields: [wardId], references: [id])
  dispenseOrders DispenseOrder[]

  @@index([orgId])
  @@index([orgId, admissionNumber])
  @@unique([orgId, admissionNumber])
}

model Location {
  id        String       @id @default(uuid()) @db.Uuid
  orgId     String       @db.Uuid
  name      String
  code      String
  type      LocationType
  parentId  String?      @db.Uuid
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  parent     Location?    @relation("LocationHierarchy", fields: [parentId], references: [id])
  children   Location[]   @relation("LocationHierarchy")
  admissions Admission[]
  dispenseOrders DispenseOrder[]

  @@index([orgId])
  @@unique([orgId, code])
}

model DispenseOrder {
  id            String              @id @default(uuid()) @db.Uuid
  orgId         String              @db.Uuid
  orderNumber   String
  patientId     String              @db.Uuid
  admissionId   String?             @db.Uuid
  type          DispenseType
  dispensedById String?             @db.Uuid
  locationId    String?             @db.Uuid
  dispensedAt   DateTime?
  notes         String?
  cancelReason  String?
  status        DispenseOrderStatus @default(PENDING)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  patient   Patient             @relation(fields: [patientId], references: [id])
  admission Admission?          @relation(fields: [admissionId], references: [id])
  location  Location?           @relation(fields: [locationId], references: [id])
  items     DispenseOrderItem[]

  @@index([orgId])
  @@index([orgId, orderNumber])
  @@unique([orgId, orderNumber])
  @@index([orgId, patientId])
  @@index([orgId, admissionId])
  @@index([orgId, status])
}

model DispenseOrderItem {
  id              String    @id @default(uuid()) @db.Uuid
  dispenseOrderId String    @db.Uuid
  drugId          String    @db.Uuid
  drugName        String
  batchNumber     String?
  quantity        Int
  dosage          String?
  frequency       String?
  duration        String?
  instructions    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  dispenseOrder DispenseOrder @relation(fields: [dispenseOrderId], references: [id], onDelete: Cascade)

  @@index([dispenseOrderId])
}
